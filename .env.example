MYSQL_DATABASE=pet_shop
MYSQL_USERNAME=petshop
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password

MYSQL_URL=jdbc:mysql://mysql:3306/pet_shop?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai

APP_UPLOAD_DIR=/app/uploads
APP_UPLOAD_URL_PREFIX=/api/uploads/
APP_ADMIN_USERNAMES=superadmin
APP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
APP_USER_JWT_SECRET=replace-with-at-least-32-random-characters
APP_USER_JWT_HOURS=6
